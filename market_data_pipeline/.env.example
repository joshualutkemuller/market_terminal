# ── Market Data Pipeline — environment ──────────────────────────────
# FRED is the official macro source. Get a free key:
#   https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Force the deterministic synthetic source (no network). 1 = offline.
MDP_OFFLINE=0

# Allow the (unofficial, best-effort) Yahoo market source. 0 disables it
# (falls back to synthetic) — set 0 if you only have FRED access.
MDP_ALLOW_YAHOO=1
